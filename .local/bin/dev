
dev_path=~/Workspace/dotfiles/nixos/dev
shell_files=("$(basename "$(pwd).nix")" default.nix shell.nix)

function file_full_path() {
  echo "$(pwd)/$1"
}

function nearest_shell() {
  if [ -z "$1" ]; then
    for shell_file in "${shell_files[@]}"; do
      file="$(file_full_path "$shell_file")"

      [ -f "$file" ] && echo "$file" && exit 0
    done
  else
    file="$(file_full_path "$1.nix")"

    [ -f "$file" ] && echo "$file" && exit 0
  fi


  if [ "$(pwd)" = "/" ]; then
    shell_file="$dev_path/$1.nix"

    [ ! -f "$shell_file" ] && exit 1

    echo "$shell_file" && exit 0
  fi

  cd ..

  nearest_shell "$1"
}

function enter_shell() {
  shell_file="$(nearest_shell "$1")"

  [ ! -f "$shell_file" ] && echo "No suitable shell file could be found!" && exit 1

  export NIXPKGS_ALLOW_UNFREE=1

  echo "Entering shell from: $shell_file"

  nix-shell --run "DEV_PROMPT=$dev_environment zsh" "$shell_file"
}

if [ ! -z "$1" ]; then
  case $1 in
    create|init)
      channel="${DEV_NIX_CHANNEL:-26.05}"
      filename="shell.nix"

      shift

      while [ "$#" -gt 0 ]; do
        case "$1" in
          --channel)
            [ -z "$2" ] && echo "Missing channel after --channel" && exit 1
            channel="$2"
            shift 2
          ;;

          *)
            filename="$1.nix"
            shift
          ;;
        esac
      done

      case "$channel" in
        unstable)
          branch="nixos-unstable"
        ;;
        *)
          branch="nixos-$channel"
        ;;
      esac

      cat > "$filename" <<EOF
let
  pkgs = import (fetchTarball {
    url = "https://github.com/NixOS/nixpkgs/archive/${branch}.tar.gz";
  }) { config.allowUnfree = true; };
in

pkgs.mkShell {
  buildInputs = with pkgs; [
  ];
}
EOF
    ;;

    edit)
      shell_file="$(nearest_shell "$2")"

      [ ! -f "$shell_file" ] && echo "No suitable shell file could be found!" && exit 1

      ${EDITOR:-nvim} "$shell_file"
    ;;

    delete|deinit|remove)
      shell_file="$(nearest_shell "$2")"

      [ ! -f "$shell_file" ] && echo "No suitable shell file could be found!" && exit 1

      echo -n "# Removing $shell_file... "

      rm -f "$shell_file" 2> /dev/null

      [ -f "$shell_file" ] && echo "Failed!" || echo "Done!"
    ;;

    show)
      shell_file="$(nearest_shell "$2")"

      [ ! -f "$shell_file" ] && echo "No suitable shell file could be found!" && exit 1

      echo "# Displaying contents for: $shell_file"

      cat "$shell_file"
    ;;

    enter)
      [ -z "$2" ] && exit 1

      dev_environment=$2

      enter_shell "$2"
    ;;

    *)
      dev_environment=$1

      enter_shell "$1"
    ;;
  esac
else
  dev_environment=$(basename "$(pwd)")

  enter_shell
fi
