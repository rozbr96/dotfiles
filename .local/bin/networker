#!/run/current-system/sw/bin/zsh

start() {
  eww update loading=true
  eww update networker-step-index=0
  eww open networker --arg monitor='[1, 0]'

  (
    t=0
    while [ ! -z "$(eww get loading)" ]; do
      v=$(awk -v t="$t" 'BEGIN {
        pi = atan2(0, -1)
        print 50 * (1 + sin(t - pi/2))
      }')

      eww update loading-start-at="$v"

      t=$(awk -v t="$t" 'BEGIN { print t + 0.12 }')
    done
  ) &

  eww update networker-networks="$(wifi list json)"
  eww update networker-step-index=1
  eww update loading=''
}

dismiss() {
  eww close networker
  eww update loading=''
  eww update networker-step-index=0
}

connect() {
  dismiss

  wifi connect_if_exists "$1"
}

case "$1" in
  start) start ;;
  dismiss) dismiss ;;
  connect) connect "$2" ;;
esac

