#!/run/current-system/sw/bin/zsh

function options_for() {
  device_type="$1"
  default_device="$(pactl get-default-${device_type})"

  pactl -f json list "${device_type}s" | jq --arg default "$default_device" '
    map(
      select(.name | endswith(".monitor") | not)
      | select(any(.ports[]?; .type != "HDMI"))
      | . as $device
      | $device.ports[]
      | select(.type != "HDMI")
      | {
        device: $device.name,
        label: $device.description,
        port: .name,
        port_description: .description,
        port_type: .type,

        icon: (
          if (.type == "Mic" and ($device.description | test("headset"; "i")))
          then "headset"
          else (.type | ascii_downcase)
          end
        ),

        port_active_for_device: (.name == $device.active_port),
        device_is_default: ($device.name == $default),
        active: (
          $device.name == $default
          and .name == $device.active_port
        )
      }
    )
  '
}

function update_eww_vars_for() {
  type="$1"

  if [ "$type" = "sink" ]; then
    volume_status="$(wpctl get-volume @DEFAULT_SINK@)"
  else
    volume_status="$(wpctl get-volume @DEFAULT_SOURCE@)"
  fi

  volume_level=$(awk '{ print $2 * 100 }' <<< "$volume_status")
  donut_volume_level=$(bc <<< "$volume_level / 1.5")
  volume_muted=$(grep -qi muted <<< "$volume_status" && echo true || echo false)

  eww update "${type}-volume-muted=$volume_muted"
  eww update "${type}-volume-level=$volume_level"
  eww update "donut-${type}-volume-level=$donut_volume_level"
}

case $1 in
  monitor)
    pactl subscribe | grep --line-buffered -E 'sink|source' | while read -r _; do
      update_eww_vars_for "sink"
      update_eww_vars_for "source"
    done
  ;;

  mixer)
    case "$2" in
      open)
        eww open mixer --arg sinks="$(options_for sink)" --arg sources="$(options_for source)" --arg monitor='[1, 0]'
      ;;

      close)
        eww close mixer
      ;;

      set)
        case "$3" in
          sink)
            pactl set-sink-port "$4" "$5"
            pactl set-default-sink "$4"
            eww close mixer
          ;;

          source)
            pactl set-source-port "$4" "$5"
            pactl set-default-source "$4"
            eww close mixer
          ;;
        esac
      ;;
    esac
  ;;

  mute)
    case "$2" in
      sink)
        case "$3" in
          toggle) wpctl set-mute @DEFAULT_SINK@ toggle ;;
          on) wpctl set-mute @DEFAULT_SINK@ 1 ;;
          off) wpctl set-mute @DEFAULT_SINK@ 0 ;;
        esac
      ;;

      source)
        case "$3" in
          toggle) wpctl set-mute @DEFAULT_SOURCE@ toggle ;;
          on) wpctl set-mute @DEFAULT_SOURCE@ 1 ;;
          off) wpctl set-mute @DEFAULT_SOURCE@ 0 ;;
        esac
      ;;
    esac

  ;;

  increase)
    case "$2" in
      sink) wpctl set-volume @DEFAULT_SINK@ ${3:-5}%+ ;;
      source) wpctl set-volume @DEFAULT_SOURCE@ ${3:-5}%+;;
    esac
    
  ;;

  decrease)
    case "$2" in
      sink) wpctl set-volume @DEFAULT_SINK@ ${3:-5}%- ;;
      source) wpctl set-volume @DEFAULT_SOURCE@ ${3:-5}%- ;;
    esac
  ;;

  set)
    case "$2" in
      sink) wpctl set-volume @DEFAULT_SINK@ $3% ;;
      source) wpctl set-volume @DEFAULT_SOURCE@ $3% ;;
    esac
  ;;
esac
