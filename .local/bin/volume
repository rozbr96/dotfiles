#!/run/current-system/sw/bin/zsh

function options_for() {
  device_type="$1"
  default_device="$(pactl get-default-${device_type})"

  pactl -f json list "${device_type}s" | jq --arg default "$default_device" '
    map(
      select(.name | endswith(".monitor") | not)
      | select(any(.ports[]?; .type != "HDMI"))
      | . as $device
      | $device.ports[]
      | select(.type != "HDMI")
      | {
        device: $device.name,
        label: $device.description,
        port: .name,
        port_description: .description,
        port_type: .type,

        icon: (
          if (.type == "Mic" and ($device.description | test("headset"; "i")))
          then "headset"
          else (.type | ascii_downcase)
          end
        ),

        port_active_for_device: (.name == $device.active_port),
        device_is_default: ($device.name == $default),
        active: (
          $device.name == $default
          and .name == $device.active_port
        )
      }
    )
  '
}

case $1 in
  monitor)
    pw-mon | grep --line-buffered sink | while read -r; do
      volume_status=$(wpctl get-volume @DEFAULT_SINK@)
      volume_level=$(echo "$volume_status" | awk '{ print $2 * 100 }')
      donut_volume_level=$(echo "$volume_level / 1.5" | bc)
      volume_muted=$(echo "$volume_status" | grep -i muted > /dev/null && echo true || echo false)

      eww update volume-muted=$volume_muted
      eww update volume-level=$volume_level
      eww update donut-volume-level=$donut_volume_level
    done
  ;;

  mixer)
    case "$2" in
      open)
        eww open mixer --arg sinks="$(options_for sink)" --arg sources="$(options_for source)" --arg monitor='[1, 0]'
      ;;

      close)
        eww close mixer
      ;;

      set)
        case "$3" in
          sink)
            pactl set-sink-port "$4" "$5"
            pactl set-default-sink "$4"
            eww close mixer
          ;;

          source)
            pactl set-source-port "$4" "$5"
            pactl set-default-source "$4"
            eww close mixer
          ;;
        esac
      ;;
    esac
  ;;

  mute)
    case $2 in
      toggle)
        wpctl set-mute @DEFAULT_SINK@ toggle
      ;;

      on)
        wpctl set-mute @DEFAULT_SINK@ 1
      ;;

      off)
        wpctl set-mute @DEFAULT_SINK@ 0
      ;;
    esac
  ;;

  increase)
    wpctl set-volume @DEFAULT_SINK@ ${2:-5}%+
  ;;

  decrease)
    wpctl set-volume @DEFAULT_SINK@ ${2:-5}%-
  ;;

  set)
    wpctl set-volume @DEFAULT_SINK@ $2%
  ;;
esac
