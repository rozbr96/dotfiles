#!/run/current-system/sw/bin/zsh

open() {
  eww update disks="$(list)"
  eww open disks --arg monitor="$(eww get monitors)"
}

close() {
  eww close disks
}

list() {
  lsblk -J -o NAME,PATH,LABEL,FSTYPE,MOUNTPOINTS,TRAN,HOTPLUG | jq '.blockdevices'
}

mount() {
  udisksctl mount -b "$1"
}

unmount() {
  udisksctl unmount -b "$1"
}

[ -z "$1" ] && list && exit 0

case "$1" in
  open|close|list|mount|unmount)
    "$1" "$2"
  ;;
esac

