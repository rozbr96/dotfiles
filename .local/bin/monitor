#!/run/current-system/sw/bin/zsh

update_volume_vars() {
  volume update_vars "sink"
  volume update_vars "source"
}

case $1 in
  network)
    network update_vars

    dbus-monitor --system \
      "type='signal',sender='org.freedesktop.NetworkManager',interface='org.freedesktop.NetworkManager.Device'" \
        | while read -r; do
            network update_vars
          done
  ;;

  volume)
    update_volume_vars

    pactl subscribe | grep --line-buffered -E 'sink|source' | while read -r; do
      update_volume_vars
    done
  ;;

  batteries)
    battery update_vars

    udevadm monitor --subsystem-match power_supply | \
      grep --line-buffered KERNEL | \
        while read -r; do
          battery update_vars
        done
  ;;

  media)
    playerctl metadata --follow \
      --format '{"status": "{{status}}","title": "{{title}}","length": "{{duration(mpris:length)}}", "position": "{{duration(position)}}", "raw_length": "{{mpris:length}}", "raw_position": "{{position}}"}' \
    |  while read -r data; do
      eww update media-metadata="$(echo "$data" | jq -c '. + {is_live: .raw_length == "9223372036854775807"}')"
    done
  ;;
esac
