
(include 'widgets/workspaces.yuck')
(include 'widgets/clock.yuck')
(include 'widgets/volume-control.yuck')

(defwindow bottom-bar
  :monitor '[1, 0]'
  :exclusive true
  :geometry (geometry
              :anchor 'bottom center')
  (box
    :hexpand true
    :width 1920
    (workspaces)
    (clock)
    (volume-control)))
