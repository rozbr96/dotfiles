
(include 'widgets/clock.yuck')
(include 'widgets/workspaces.yuck')

(defwindow bottom-center-bar
  :monitor '[1, 0]'
  :exclusive true
  :geometry (geometry
              :width '100px'
              :height '20px'
              :anchor 'bottom center')
  (box
    :orientation 'h'
    (workspaces)
    (clock)))

