
(include 'widgets/networks-list.yuck')
(include 'widgets/loading.yuck')
(include 'widgets/network-password-input.yuck')

(defwidget networker []
  (stack
    :transition 'crossfade'
    :selected networker-step-index
    (centerbox
      :height 88
      (label)
      (loading)
      (label))
    (networks-list)
    (network-password-input)))
